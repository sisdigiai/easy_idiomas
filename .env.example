# GEMINI_API_KEY: configure only in local/hosting secrets, never commit a real key.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"


# Supabase public browser config. The anon key is public by design, but keep
# real values in local .env files or hosting env vars.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# ─── GitHub credentials for `git push` ───────────────────────────────────
# Personal Access Token usado pelo credential.helper local do repo
# para autenticar `git push` sem popup.
#
# Como gerar:
# 1. Acesse https://github.com/settings/tokens
# 2. "Generate new token (classic)"
# 3. Escopo: marque "repo"
# 4. Expiration: defina prazo (recomendado: 90 dias)
#
# Documentação completa da convenção:
# D:\projetos\diferentes\docs\digiai\docs\07-operacao\convencoes-tecnicas-ecossistema-sisdigiai.md
GITHUB_USERNAME="sisdigiai"
GITHUB_TOKEN="ghp_SUBSTITUA_PELO_SEU_TOKEN"
