# GEMINI_API_KEY: configure only in local/hosting secrets, never commit a real key.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"


# Supabase public browser config. The anon key is public by design, but keep
# real values in local .env files or hosting env vars.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
